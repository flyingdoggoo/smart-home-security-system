APP_NAME=Smart Home Guardian
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Asia/Saigon

# ESP32-CAM
ESP32_CAM_BASE_URL=http://192.168.1.50
CAMERA_CAPTURE_PATH=/capture
VISION_INTERVAL_SEC=1.0
FACE_DETECTOR_MODEL=hog
FACE_MATCH_THRESHOLD=0.5
FACE_SMOOTHING_WINDOW=5
OWNER_EMBEDDINGS_FILE=data/faces/owner_embeddings/owner_embeddings.npz

# Rules
AUTO_RELOCK_SEC=12
GAS_THRESHOLD=1800
STRANGER_ALERT_COOLDOWN_SEC=20
GAS_ALERT_COOLDOWN_SEC=20

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=smart-home-server
MQTT_TOPIC_DOOR_CMD=home/io/cmd/door
MQTT_TOPIC_LIGHT_CMD=home/io/cmd/light
MQTT_TOPIC_TELEMETRY=home/io/telemetry
MQTT_TOPIC_VISION_STATE=home/vision/state

# Blynk
BLYNK_ENABLED=false
BLYNK_SERVER=blynk.cloud
BLYNK_TOKEN=
BLYNK_PIN_DOOR=V0
BLYNK_PIN_LIGHT=V1
BLYNK_PIN_GAS=V2
BLYNK_PIN_FACE=V3
